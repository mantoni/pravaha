{
  "name": "pravaha",
  "description": "Pravaha turns human workflow into explicit contracts that agents can execute.",
  "version": "0.0.1",
  "type": "module",
  "main": "./lib/pravaha.js",
  "types": "./lib/pravaha.d.ts",
  "exports": {
    ".": {
      "types": "./lib/pravaha.d.ts",
      "default": "./lib/pravaha.js"
    },
    "./flow": {
      "types": "./lib/flow.d.ts",
      "default": "./lib/flow.js"
    },
    "./bin/pravaha.js": "./bin/pravaha.js"
  },
  "files": [
    "bin/pravaha.js",
    "lib/**/*.d.ts",
    "lib/**/*.js",
    "!bin/**/*.test.d.ts",
    "!bin/**/*.test-helpers.d.ts",
    "!test/**",
    "!bin/**/*.test.js",
    "!bin/**/*.test-helpers.js",
    "!lib/**/*.test.d.ts",
    "!lib/**/*.test-helpers.d.ts",
    "!lib/**/*.test.js",
    "!lib/**/*.test-helpers.js"
  ],
  "bin": {
    "pravaha": "bin/pravaha.js"
  },
  "homepage": "https://github.com/mantoni/pravaha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mantoni/pravaha.git"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "scripts": {
    "all": "npm run check:lint && npm run check:format && npm run check:types && npm run check:patram && npm run check:knip && npm run check:knip:production && npm run test:coverage && npm run check:dupes",
    "check:dupes": "jscpd --min-tokens 100 --min-lines 6 --mode mild --threshold 0 --reporters console --gitignore --ignore \"**/.pravaha/**\" .",
    "check:format": "prettier --check .",
    "check:knip": "knip",
    "check:knip:production": "knip --production --include exports",
    "check:lint": "eslint .",
    "check:patram": "patram check && node ./bin/pravaha.js validate",
    "check:staged": "lint-staged",
    "check:types": "tsc",
    "postpack": "node scripts/clean-package-api-declarations.js",
    "postversion": "git push && git push --tags",
    "prepack": "node scripts/build-package-api-declarations.js",
    "preversion": "npm run all",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "version": "node scripts/update-changelog.js && git add CHANGELOG.md package.json package-lock.json"
  },
  "lint-staged": {
    "*.{js,ts,json,md}": "prettier --check",
    "*.{js,ts}": [
      "eslint",
      "vitest related --run --passWithNoTests --tagsFilter='!lint-staged-excluded'"
    ]
  },
  "dependencies": {
    "globby": "^16.1.1",
    "patram": "^0.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitest/coverage-istanbul": "4.1.1",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.1.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  }
}
