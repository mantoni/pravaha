{
  "include": [
    "README.md",
    "docs/**/*.md",
    "bin/**/*.js",
    "lib/**/*.js",
    "scripts/**/*.js",
    "test/**/*.js"
  ],
  "classes": {
    "document": {
      "builtin": true
    },
    "contract": {
      "label": "Contract",
      "schema": {
        "document_path_class": "contracts",
        "fields": {
          "status": {
            "presence": "required"
          },
          "decided_by": {
            "presence": "optional"
          },
          "depends_on": {
            "presence": "optional"
          },
          "root_flow": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "decision": {
      "label": "Decision",
      "schema": {
        "document_path_class": "decisions",
        "fields": {
          "status": {
            "presence": "required"
          },
          "tracked_in": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "task": {
      "label": "Task",
      "schema": {
        "document_path_class": "tasks",
        "fields": {
          "status": {
            "presence": "required"
          },
          "tracked_in": {
            "presence": "required"
          },
          "decided_by": {
            "presence": "optional"
          },
          "depends_on": {
            "presence": "optional"
          },
          "implements": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "flow": {
      "label": "Flow",
      "schema": {
        "document_path_class": "flows",
        "fields": {
          "status": {
            "presence": "required"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "convention": {
      "label": "Convention",
      "schema": {
        "document_path_class": "conventions",
        "fields": {
          "status": {
            "presence": "required"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "plan": {
      "label": "Plan",
      "schema": {
        "document_path_class": "plans",
        "fields": {
          "status": {
            "presence": "required"
          }
        },
        "unknown_fields": "ignore"
      }
    },
    "reference": {
      "label": "Reference",
      "schema": {
        "document_path_class": "reference",
        "fields": {
          "status": {
            "presence": "optional"
          }
        },
        "unknown_fields": "ignore"
      }
    }
  },
  "fields": {
    "status": {
      "type": "enum",
      "values": [
        "proposed",
        "active",
        "ready",
        "blocked",
        "review",
        "done",
        "dropped",
        "accepted",
        "superseded"
      ],
      "display": {
        "order": 1
      }
    },
    "tracked_in": {
      "type": "path",
      "path_class": "workflow_docs"
    },
    "decided_by": {
      "type": "path",
      "multiple": true,
      "path_class": "decisions"
    },
    "depends_on": {
      "type": "path",
      "multiple": true,
      "path_class": "workflow_docs"
    },
    "implements": {
      "type": "path",
      "multiple": true,
      "path_class": "workflow_docs"
    },
    "root_flow": {
      "type": "path",
      "path_class": "flows"
    }
  },
  "path_classes": {
    "contracts": {
      "prefixes": ["docs/contracts/"]
    },
    "decisions": {
      "prefixes": ["docs/decisions/"]
    },
    "tasks": {
      "prefixes": ["docs/tasks/"]
    },
    "flows": {
      "prefixes": ["docs/flows/"]
    },
    "conventions": {
      "prefixes": ["docs/conventions/"]
    },
    "plans": {
      "prefixes": ["docs/plans/"]
    },
    "reference": {
      "prefixes": ["docs/reference/"]
    },
    "workflow_docs": {
      "prefixes": [
        "docs/contracts/",
        "docs/tasks/",
        "docs/flows/",
        "docs/decisions/",
        "docs/conventions/",
        "docs/plans/",
        "docs/reference/"
      ]
    }
  },
  "queries": {
    "change-queue": {
      "where": "($class=contract or $class=task or $class=decision) and status in [proposed, active, ready, blocked, review]"
    },
    "active-contracts": {
      "where": "$class=contract and status in [proposed, active, blocked, review]"
    },
    "contracts-missing-decisions": {
      "where": "$class=contract and status in [proposed, active, blocked, review] and none(out:decided_by, $class=decision and status=accepted)"
    },
    "ready-tasks": {
      "where": "$class=task and status=ready and none(out:depends_on, status not in [done, dropped])"
    },
    "blocked-work": {
      "where": "($class=contract or $class=task) and status=blocked"
    },
    "review-queue": {
      "where": "($class=contract or $class=task) and status=review"
    },
    "decision-backlog": {
      "where": "$class=decision and status in [proposed, active]"
    },
    "orphan-tasks": {
      "where": "$class=task and none(out:tracked_in, $class=contract)"
    }
  },
  "relations": {
    "tracked_in": {
      "from": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ],
      "to": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ]
    },
    "decided_by": {
      "from": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ],
      "to": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ]
    },
    "depends_on": {
      "from": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ],
      "to": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ]
    },
    "implements": {
      "from": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ],
      "to": [
        "document",
        "contract",
        "decision",
        "task",
        "flow",
        "convention",
        "plan",
        "reference"
      ]
    },
    "root_flow": {
      "from": ["contract"],
      "to": ["flow"]
    }
  },
  "mappings": {
    "markdown.directive.kind": {
      "node": {
        "class": "document",
        "field": "$class"
      }
    },
    "markdown.directive.id": {
      "node": {
        "class": "document",
        "field": "$id",
        "key": "value"
      }
    },
    "markdown.directive.status": {
      "node": {
        "class": "document",
        "field": "status"
      }
    },
    "markdown.directive.tracked_in": {
      "emit": {
        "relation": "tracked_in",
        "target": "path",
        "target_class": "document"
      }
    },
    "markdown.directive.decided_by": {
      "emit": {
        "relation": "decided_by",
        "target": "path",
        "target_class": "document"
      }
    },
    "markdown.directive.depends_on": {
      "emit": {
        "relation": "depends_on",
        "target": "path",
        "target_class": "document"
      }
    },
    "markdown.directive.implements": {
      "emit": {
        "relation": "implements",
        "target": "path",
        "target_class": "document"
      }
    },
    "markdown.directive.root_flow": {
      "emit": {
        "relation": "root_flow",
        "target": "path",
        "target_class": "flow"
      }
    },
    "jsdoc.directive.tracked_in": {
      "emit": {
        "relation": "tracked_in",
        "target": "path",
        "target_class": "document"
      }
    },
    "jsdoc.directive.decided_by": {
      "emit": {
        "relation": "decided_by",
        "target": "path",
        "target_class": "document"
      }
    },
    "jsdoc.directive.depends_on": {
      "emit": {
        "relation": "depends_on",
        "target": "path",
        "target_class": "document"
      }
    },
    "jsdoc.directive.implements": {
      "emit": {
        "relation": "implements",
        "target": "path",
        "target_class": "document"
      }
    },
    "jsdoc.directive.root_flow": {
      "emit": {
        "relation": "root_flow",
        "target": "path",
        "target_class": "flow"
      }
    }
  }
}
