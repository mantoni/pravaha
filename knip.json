{
  "$schema": "./node_modules/knip/schema.json",
  "project": [
    "*.js!",
    "bin/**/*.js!",
    "lib/**/*.js!",
    "lib/**/*.ts!",
    "scripts/**/*.js",
    "test/**/*.js"
  ],
  "ignoreIssues": {
    "lib/config/load-pravaha-config.js": ["exports"],
    "lib/plugins/core/types.ts": ["types"],
    "lib/runtime/dispatch/graph.js": ["exports"],
    "lib/shared/types/patram-types.ts": ["types"],
    "**/*.types.ts": ["types"],
    "**/*.d.ts": ["unresolved"]
  },
  "tags": ["-@internal"]
}
